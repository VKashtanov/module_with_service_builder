<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.3.0//EN"
		"http://www.liferay.com/dtd/liferay-service-builder_7_3_0.dtd">

<service-builder dependency-injector="ds" package-path="ru.kashtanov.dad">
	<namespace>Dad</namespace>

	<entity name="Dad" local-service="true" remote-service="false">

		<!-- Primary key - DON"T ADD TYPE IDENTITY , LET IT BE BY DEFAULT "none"-->
		<column name="dadId" type="long" primary="true" />

		<!-- Audit fields -->
		<column name="groupId" type="long"/>
		<column name="companyId" type="long"/>
		<column name="userId" type="long"/>
		<column name="userName" type="String"/>
		<column name="createDate" type="Date"/>
		<column name="modifiedDate" type="Date"/>

		<!-- Custom fields -->
		<column name="name" type="String"/>
		<column name="weight" type="double"/>
		<column name="description" type="String"/>

		<finder name="ByName" return-type="Collection">
			<finder-column name="name"/>
		</finder>

	</entity>
</service-builder>